---
import type { GetStaticPathsOptions } from 'astro';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import PostsList from '../../../../components/PostsList.astro';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const collection = await getCollection('posts');
  const allPosts = collection.toSorted((postA, postB) => postB.data.date.getTime() - postA.data.date.getTime());

  const readingTimeEntries = await Promise.all(
    allPosts.map(async (post) => {
      const { remarkPluginFrontmatter } = await render(post);
      const time = (remarkPluginFrontmatter as { readingTime?: number }).readingTime ?? 1;
      return [post.id, time] as const;
    }),
  );
  const readingTimes: Record<string, number> = Object.fromEntries(readingTimeEntries);

  const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags))];

  return allTags.flatMap((tag) => {
    const tagPosts = allPosts.filter((post) => post.data.tags.includes(tag));
    return paginate(tagPosts, {
      pageSize: 10,
      params: { tag },
      props: { readingTimes, tag },
    });
  });
}

const { page, tag, readingTimes } = Astro.props;
---

<BaseLayout title={`Tagged: ${tag}`} description={`Posts tagged with "${tag}".`}>
  <PostsList
    title={`Tagged: ${tag}`}
    posts={page.data}
    readingTimes={readingTimes}
    page={{
      currentPage: page.currentPage,
      lastPage: page.lastPage,
      url: { prev: page.url.prev, next: page.url.next },
    }}
  />
</BaseLayout>
