---
import { Icon } from 'astro-icon/components';
import DarkModeToggle from './DarkModeToggle.vue';

const { class: className, ...rest } = Astro.props;
---

<header class:list={["flex items-center justify-between py-6", className]} {...rest}>
  <a href="/" class="text-xs font-medium tracking-widest text-jade-12 uppercase dark:text-jadedark-12">
    Seán O'Grady
  </a>

  <div class="flex items-center gap-6">
    <a href="/posts" class="text-xs font-medium tracking-widest text-jade-12 uppercase dark:text-jadedark-12">
      Posts
    </a>
    <DarkModeToggle client:load>
      <Icon name="bi:moon" class="size-5 block dark:hidden" slot="light-icon" />
      <Icon name="bi:moon-fill" class="size-5 hidden dark:block" slot="dark-icon" />
    </DarkModeToggle>
  </div>
</header>
