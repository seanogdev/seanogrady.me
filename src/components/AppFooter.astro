---
import AppSocialLinks from './AppSocialLinks.astro';
import AppNowPlaying from './AppNowPlaying.vue';
import { DateTime } from 'luxon';
---

<footer class="mt-16 w-full bg-sage-3 dark:bg-sagedark-2">
  <div class="mx-auto grid max-w-6xl grid-cols-12 gap-4 px-4 py-12 md:gap-8 lg:gap-12">
    <div class="col-span-12 md:col-span-8 md:col-start-3">
      <div class="grid grid-cols-3 gap-4 md:gap-8 lg:gap-12">
        <div class="col-span-3 md:col-span-1">
          <AppSocialLinks />
        </div>
        <div class="col-span-3 md:col-span-2">
          <AppNowPlaying client:visible />
        </div>
      </div>
      <p class="mt-12 text-center text-sm text-sage-11 dark:text-sagedark-11">
        &copy; {DateTime.now().year} Sean O'Grady
      </p>
    </div>
  </div>
</footer>
